# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Backend
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/copilot
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/copilot
BACKEND_CORS_ORIGINS=http://localhost:3000
CLERK_JWT_ISSUER=
CLERK_JWKS_URL=
ALLOW_ANONYMOUS_DEMO=true

# AI providers - configure at least one for live AI output
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ENABLE_SENTENCE_TRANSFORMERS=false

# Storage
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
CLOUDINARY_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# Security and observability
RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=INFO
