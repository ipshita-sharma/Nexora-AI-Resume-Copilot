{
  "name": "ai-resume-interview-copilot",
  "private": true,
  "version": "1.0.0",
  "description": "Production-grade AI SaaS for resume analysis, ATS scoring, JD matching, mock interviews, and learning roadmaps.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "lint": "npm run lint --workspace apps/web",
    "typecheck": "npm run typecheck --workspace apps/web",
    "api:dev": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "api:test": "cd apps/api && pytest",
    "api:lint": "cd apps/api && ruff check app tests"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0",
    "python": ">=3.11"
  }
}
